# ============================================================
# Cement & RMX Supply Chain AI Agents — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values

# -----------------------------------------------------------
# LLM Provider (choose one or both)
# -----------------------------------------------------------

# GROQ API (FREE tier available — recommended for fast inference)
# Get your key at: https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here

# OpenAI API (fallback / GPT-4 for complex reasoning)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_api_key_here

# -----------------------------------------------------------
# App Configuration
# -----------------------------------------------------------
# Primary LLM provider: "groq" | "openai"
LLM_PROVIDER=groq

# Groq model options:
# - llama-3.1-70b-versatile (best quality, free)
# - llama-3.1-8b-instant (fastest, free)
# - mixtral-8x7b-32768 (good for long context)
GROQ_MODEL=llama-3.1-70b-versatile

# OpenAI model (fallback)
OPENAI_MODEL=gpt-4o-mini

# -----------------------------------------------------------
# Optional: Simulated Sensor Data (demo mode)
# -----------------------------------------------------------
# Set to "true" to use simulated real-time plant data
DEMO_MODE=true

# Next.js
NEXTAUTH_SECRET=your_random_secret_here_change_this
NEXTAUTH_URL=http://localhost:3000
